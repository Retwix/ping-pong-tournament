# Copy this file to ".env" and fill in your Supabase project values.
# Find them in Supabase: Project Settings -> API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Slack notifications (optional) ---
# Set to "true" once you've deployed the slack-notify Edge Function (see
# supabase/SLACK_SETUP.md). When false/unset, the app never calls Slack.
VITE_SLACK_ENABLED=false
